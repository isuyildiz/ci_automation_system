# Kopyala: cp .env.example .env ve değerleri doldur

# Orchestrator
JWT_SECRET_KEY=buraya-guclu-rastgele-bir-anahtar-koy
DATABASE_URL=postgresql+asyncpg://ci_user:ci_pass@postgres:5432/ci_db
REDIS_URL=redis://redis:6379/0
JWT_EXPIRE_MINUTES=60
MAX_CONCURRENT_PIPELINES=3
PIPELINE_TIMEOUT_SEC=600

# Repo Manager
GITHUB_TOKEN=ghp_...         # GitHub Personal Access Token (private repo klonlama için, public repolar için boş bırakılabilir)
GITHUB_WEBHOOK_SECRET=change-me  # GitHub webhook ayarlarındaki secret ile aynı olmalı

# Trigger API (opsiyonel, boş bırakılırsa doğrulama yapılmaz)
# TRIGGER_API_KEY=
